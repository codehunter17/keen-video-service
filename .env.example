# Copy to .env and fill in. Everything has a sensible default except PEXELS_API_KEY.

# --- Media (REQUIRED) ---
PEXELS_API_KEY=

# --- Scene-mapping LLM (optional; free-first, falls back to a keyword heuristic) ---
# Provide ONE of these to get rich "visual search prompts". Without them the
# service still works using a deterministic keyword heuristic.
GROQ_API_KEY=
GEMINI_API_KEY=
SCENE_LLM_MODEL=llama-3.3-70b-versatile

# --- Voiceover ---
TTS_PROVIDER=edge                 # "edge" (free) | "elevenlabs"
EDGE_DEFAULT_VOICE=en-US-AriaNeural
ELEVENLABS_API_KEY=

# --- Video output ---
VIDEO_WIDTH=1080                  # 1080x1920 = vertical reel; set 1920x1080 for landscape
VIDEO_HEIGHT=1920
FPS=30
PEXELS_ORIENTATION=portrait       # portrait | landscape | square
OUTPUT_DIR=output
WORK_DIR=work

# --- Auth between Keen (Node) and this service ---
# Keen must send `X-Keen-Key: <this>` on requests. Empty = open (dev only).
SERVICE_API_KEY=

# Public base URL where rendered files are served (for building output_url).
PUBLIC_BASE_URL=http://localhost:8000
