# Copy to .env and fill in. Everything has a sensible default except PEXELS_API_KEY.

# --- Media (REQUIRED) ---
PEXELS_API_KEY=

# --- Scene-mapping LLM (optional; free-first, falls back to a keyword heuristic) ---
# Provide ONE of these to get rich "visual search prompts". Without them the
# service still works using a deterministic keyword heuristic.
GROQ_API_KEY=
GEMINI_API_KEY=
SCENE_LLM_MODEL=llama-3.3-70b-versatile

# --- Voiceover (Hindi-first fallback chain) ---
# Providers tried left→right until one succeeds. If edge 403s (common on
# datacenter IPs), it auto-falls-back to ElevenLabs — no failed renders.
TTS_CHAIN=edge,elevenlabs         # "edge" (free) | "elevenlabs" (paid); comma-separated
EDGE_DEFAULT_VOICE=hi-IN-SwaraNeural   # Hindi female (free). Other: hi-IN-MadhurNeural (m)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=o6qTxWUeRyzRYZyUNDVJ   # multilingual female (Hindi-capable)
ELEVENLABS_MODEL=eleven_flash_v2_5         # supports Hindi
# CAPTION_FONT defaults to Noto Sans Devanagari (baked in the image) for Hindi captions.

# --- Video output ---
VIDEO_WIDTH=1080                  # 1080x1920 = vertical reel; set 1920x1080 for landscape
VIDEO_HEIGHT=1920
FPS=30
PEXELS_ORIENTATION=portrait       # portrait | landscape | square
OUTPUT_DIR=output
WORK_DIR=work

# --- Auth between Keen (Node) and this service ---
# Keen must send `X-Keen-Key: <this>` on requests. Empty = open (dev only).
# IMPORTANT: set this on the HF Space AND set the SAME value as VIDEO_SERVICE_KEY
# in Vercel — otherwise the render API is public and anyone can burn credits.
SERVICE_API_KEY=

# --- Cost guard ---
# Max renders accepted per UTC day (each costs an ElevenLabs call + CPU).
# 0 = unlimited. Set a ceiling (e.g. 50) before opening reels to traffic.
MAX_RENDERS_PER_DAY=0

# Public base URL where rendered files are served (for building output_url).
# On Hugging Face this is auto-detected from SPACE_HOST — leave unset there.
# Set it only for local/other hosting. PEXELS_API_KEY (above) MUST be set or
# every scene falls back to a solid-colour background (no stock footage).
# PUBLIC_BASE_URL=http://localhost:8000
